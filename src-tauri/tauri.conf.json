{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoiceFlow AI",
  "version": "1.0.16",
  "identifier": "com.voiceflow.ai",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "语音随写",
        "url": "index.html",
        "width": 520,
        "height": 450,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": false,
        "visible": false,
        "additionalBrowserArgs": "--use-fake-ui-for-media-stream --proxy-bypass-list=localhost,127.0.0.1,tauri.localhost,*.localhost"
      },
      {
        "label": "indicator",
        "title": "VoiceFlow Island",
        "url": "pill.html?v=2",
        "width": 320,
        "height": 100,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "focusable": false,
        "additionalBrowserArgs": "--use-fake-ui-for-media-stream --proxy-bypass-list=localhost,127.0.0.1,tauri.localhost,*.localhost"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: http://localhost:* ws://localhost:* ipc: http://ipc.localhost http://tauri.localhost; img-src 'self' data: blob:; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' blob:; worker-src 'self' blob:; style-src 'self' 'unsafe-inline';"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://updater-proxy-nine.vercel.app/api/index"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXkgRjAyRjVCNDlCNDkyMDhGMgpSV1R5Q0pLMFNWc3Y4TTNZZXZVcG13OEd0SlRIdFlIbDV1eCtCZzY3N1AvdXBXQXpjUWNoVDFJVQo="
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "languages": [
          "SimpChinese"
        ]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
